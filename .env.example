# App
APP_NAME=propflow
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./propflow_demo.db
# Production: postgresql+asyncpg://propflow:propflow@localhost:5432/propflow
DATABASE_POOL_SIZE=10

# Redis (required for LangGraph checkpoints + timeouts)
REDIS_URL=redis://localhost:6379/0

# WhatsApp Meta Cloud API
META_WHATSAPP_TOKEN=your_meta_token_here
META_PHONE_NUMBER_ID=your_phone_number_id
META_WEBHOOK_VERIFY_TOKEN=propflow-dev-verify-token
META_API_VERSION=v23.0

# Anthropic Claude API
# ANTHROPIC_MODEL_SMART → used for Vision AI diagnosis and complex reasoning
# ANTHROPIC_MODEL_FAST  → used for intent classification and simple responses
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL_SMART=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MAX_RETRIES=3

# Orchestration timeouts (seconds)
TIMEOUT_PHOTO_REMINDER_SECONDS=86400
TIMEOUT_LANDLORD_ESCALATION_SECONDS=1800
TIMEOUT_CONTRACTOR_CONFIRM_SECONDS=900
TIMEOUT_WORKER_POLL_SECONDS=5.0

# Sentry (optional)
SENTRY_DSN=
