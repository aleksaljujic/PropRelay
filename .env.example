# App
APP_NAME=propflow
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://propflow:propflow@localhost:5432/propflow
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp Meta Cloud API
META_WHATSAPP_TOKEN=your_token_here
META_PHONE_NUMBER_ID=your_phone_id
META_WEBHOOK_VERIFY_TOKEN=your_verify_token
META_API_VERSION=v23.0

# Middleware smoke test
# E.164 digits only, no "+" — e.g. 491511234567
# Tenant number is NOT needed — it comes from the "from" field when they message
TEST_LANDLORD_PHONE=your_phone_number_here

# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Sentry (optional)
SENTRY_DSN=
